generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String?
  passwordHash     String
  createdAt        DateTime          @default(now())
  settings         UserSettings?
  trips            Trip[]
  apiKeys          ApiKey[]
  expenses         Expense[]
  reimbursements   Reimbursement[]
  webhookEndpoints WebhookEndpoint[]
}

enum ExpenseType {
  MILEAGE
  MEALS
  LODGING
  SUPPLIES
  OTHER
}

enum ExpenseStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
  REIMBURSED
}

model Expense {
  id              String         @id @default(cuid())
  userId          String
  tripId          String?        @unique
  reimbursementId String?
  type            ExpenseType
  amount          Float
  currency        String         @default("CAD")
  date            DateTime       @default(now())
  description     String         @default("")
  receiptUrl      String?
  status          ExpenseStatus  @default(PENDING)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip            Trip?          @relation(fields: [tripId], references: [id], onDelete: SetNull)
  reimbursement   Reimbursement? @relation(fields: [reimbursementId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([reimbursementId])
}

enum ReimbursementStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PAID
}

model Reimbursement {
  id          String              @id @default(cuid())
  userId      String
  title       String              @default("")
  notes       String              @default("")
  status      ReimbursementStatus @default(DRAFT)
  submittedAt DateTime?
  approvedAt  DateTime?
  paidAt      DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses    Expense[]

  @@index([userId, status])
}

model WebhookEndpoint {
  id        String   @id @default(cuid())
  userId    String
  url       String
  secret    String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  keyPrefix  String    @unique
  hashedKey  String
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserSettings {
  id             String @id @default(cuid())
  userId         String @unique
  startingPointA Json
  startingPointB Json
  mileageRate    Float  @default(0)
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Trip {
  id              String    @id @default(cuid())
  userId          String
  date            DateTime  @default(now())
  totalKm         Float
  purpose         String    @default("")
  notes           String    @default("")
  returnedToStart Boolean   @default(false)
  startingPoint   Json
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  legs            TripLeg[]
  expense         Expense?

  @@index([userId, date])
}

model TripLeg {
  id         String @id @default(cuid())
  tripId     String
  index      Int
  fromAddr   String
  fromLat    Float
  fromLng    Float
  toAddr     String
  toLat      Float
  toLng      Float
  distanceKm Float
  trip       Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}
