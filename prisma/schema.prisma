generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  passwordHash String
  createdAt    DateTime      @default(now())
  settings     UserSettings?
  trips        Trip[]
}

model UserSettings {
  id             String @id @default(cuid())
  userId         String @unique
  startingPointA Json
  startingPointB Json
  mileageRate    Float  @default(0)
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Trip {
  id              String    @id @default(cuid())
  userId          String
  date            DateTime  @default(now())
  totalKm         Float
  purpose         String    @default("")
  notes           String    @default("")
  returnedToStart Boolean   @default(false)
  startingPoint   Json
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  legs            TripLeg[]

  @@index([userId, date])
}

model TripLeg {
  id         String @id @default(cuid())
  tripId     String
  index      Int
  fromAddr   String
  fromLat    Float
  fromLng    Float
  toAddr     String
  toLat      Float
  toLng      Float
  distanceKm Float
  trip       Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}
